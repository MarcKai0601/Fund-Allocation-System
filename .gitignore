# =========================
# Backend (Python)
# =========================
# 虛擬環境與編譯快取
venv/
.venv/
env/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# =========================
# Frontend (Node.js / Next.js)
# =========================
# 依賴套件 (最肥大的東西)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js 建置檔案與快取
.next/
out/
build/
dist/

# =========================
# Environment Variables (環境變數/機密資訊)
# =========================
# 絕對不要把金鑰和密碼推上 Git
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# =========================
# IDE / OS (編輯器與系統產生檔案)
# =========================
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db