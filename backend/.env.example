DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/fund_allocation
REDIS_URL=redis://localhost:6379/0
FUGLE_API_KEY=your_fugle_api_key_here
# 第二組 Fugle token，專供新增交易選股時即時報價（避免與定時刷新的 token 相互干擾）
FUGLE_API_KEY_QUOTE=your_second_fugle_api_key_here
# CORS：多個來源用逗號分隔，Zeabur 部署時填入 https://your-frontend.zeabur.app
ALLOWED_ORIGINS=http://localhost:3000
